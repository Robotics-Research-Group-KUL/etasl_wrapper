#!/bin/sh
#

if [ "x$LUA_PATH" = "x" ]; then
   LUA_PATH=";"
fi


luapath_append ()
{
    if [[ "$LUA_PATH" =~ (;)"${1}"(;|$) ]]
    then
        return 0
    fi
    export LUA_PATH="$LUA_PATH;${1}"
}


luacpath_append ()
{
    if [[ "$LUA_CPATH" =~ (;)"${1}"(;|$) ]]
    then
        return 0
    fi
    export LUA_CPATH="$LUA_CPATH;${1}"
}

luapath_append "@CMAKE_INSTALL_PREFIX@/lib/etasl1.5/?.lua"
luapath_append "@CMAKE_INSTALL_PREFIX@/lib/etasl1.5/xml2lua/?.lua"

luacpath_append "@CMAKE_INSTALL_PREFIX@/lib/?.so"

#export LUA_PATH="$LUA_PATH;@CMAKE_INSTALL_PREFIX@/lib/etasl1.5/?.lua;@CMAKE_INSTALL_PREFIX@/lib/etasl1.5/xml2lua/?.lua"
#export LUA_CPATH="$LUA_CPATH;@CMAKE_INSTALL_PREFIX@/lib/?.so"

